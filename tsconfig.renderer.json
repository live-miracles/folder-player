{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "types": ["vite/client"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["renderer/*"]
        }
    },
    "include": ["renderer"]
}
