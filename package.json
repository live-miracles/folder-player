{
    "name": "folder-player",
    "version": "0.1.0",
    "description": "Launch vMix playlists directly from folders",
    "homepage": "https://github.com/live-miracles/folder-player#readme",
    "bugs": {
        "url": "https://github.com/live-miracles/folder-player/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/live-miracles/folder-player.git"
    },
    "license": "MIT",
    "author": "",
    "type": "commonjs",
    "main": "dist/main/main.js",
    "scripts": {
        "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
        "dev:main": "tsc -p tsconfig.main.json --watch",
        "dev:renderer": "vite",
        "dev:electron": "wait-on http://localhost:5173 dist/main/main.js && electronmon .",
        "build": "npm run build:main && npm run build:renderer",
        "build:main": "tsc -p tsconfig.main.json",
        "build:renderer": "vite build",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "electron": "^41.0.2",
        "electronmon": "^2.0.4",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "wait-on": "^9.0.4"
    },
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    }
}
