{
    "name": "folder-player",
    "version": "0.1.0",
    "description": "Folder Player for vMix automation.",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc -p backend && tsc -p preload && tsc -p ui",
        "dist": "npm run build && electron-builder",
        "publish": "npm run build && electron-builder --publish=always",
        "dev": "concurrently \"tsc -p backend -w\" \"tsc -p preload -w\" \"tsc -p ui -w\" \"electronmon .\"",
        "css": "npx tailwindcss -i ./ui/input.css -o ./ui/dist/output.css --watch",
        "format": "prettier --write ."
    },
    "repository": {
        "type": "git",
        "url": "git@github-2:live-miracles/folder-player.git"
    },
    "keywords": [],
    "author": "Nandisha",
    "license": "MIT",
    "type": "module",
    "build": {
        "appId": "com.livemiracles.folderplayer",
        "productName": "Folder Player",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "ui/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "ui/icon-256.ico"
        },
        "publish": {
            "provider": "github",
            "owner": "live-miracles",
            "repo": "folder-player"
        }
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.1",
        "@types/node": "^25.5.0",
        "@types/semver": "^7.7.1",
        "concurrently": "^9.2.1",
        "daisyui": "^5.5.19",
        "electron": "^41.0.2",
        "electron-builder": "^26.8.1",
        "electronmon": "^2.0.4",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "electron-updater": "^6.8.3",
        "fast-xml-parser": "^5.5.6"
    }
}
